root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,yml,yaml,toml,json}]
indent_size = 2

# MiniJinja wrapper templates under `resources/agents/.<host>/` are
# authored without a trailing newline so the `{% include %}` directive
# pastes the module body — which carries its own trailing newline — at
# end-of-file. Adding `\n` after `%}` produces a double trailing newline
# in the rendered SKILL.md / subagent files and breaks the
# `dogfood_outputs_match_committed_tree` byte-equivalence guard
# (SPEC-0016 CHK-008). The renderer relies on
# `MiniJinja::Environment::set_keep_trailing_newline(true)` to surface
# the module body's `\n` as the rendered file's sole trailing newline.
[*.tmpl]
insert_final_newline = false

[Makefile]
indent_style = tab
